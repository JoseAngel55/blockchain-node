# Puerto de este nodo (cada integrante usa uno diferente)
PORT=8003

# ID único de este nodo (usa tu nombre o iniciales)
NODE_ID=nodo-express-angel

# Supabase
SUPABASE_URL=url_de_supabase
SUPABASE_KEY=anon_key_de_supabase
# Dificultad del Proof of Work (número de ceros al inicio del hash)
DIFFICULTY=3

# Nodos conocidos al arrancar (opcional, separados por coma)
# KNOWN_NODES=http://localhost:8001,http://localhost:8002
KNOWN_NODES=
